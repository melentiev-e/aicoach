{
  "name": "aicoach-fetcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone fetcher (ADR-0001): pulls from platforms, normalizes, writes /logs/. The coach agent never runs this.",
  "scripts": {
    "test": "node --test",
    "fetch": "node fetch-all.js",
    "fetch:strava": "node fetch-strava.js",
    "workouts:garmin": "node generate-garmin-workouts.js",
    "workouts:push": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\push-garmin-workouts-mtp.ps1 -Target Workouts",
    "workouts:push:newfiles": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\push-garmin-workouts-mtp.ps1 -Target NewFiles"
  },
  "dependencies": {
    "@garmin/fitsdk": "^21.205.0"
  }
}
